#!/usr/bin/env bash
set -euo pipefail

DEFAULT_REPO="Code-Vo-Van/skills"
DEFAULT_REF="main"
INDEX_FILE_JSON="skills-index.json"
INDEX_FILE_TSV="skills-index.tsv"

usage() {
  cat <<'EOF'
Usage:
  bin/install <skill-name> [--repo <owner/repo>] [--ref <git-ref>]
  bin/install --scaffold <skill-name>
  bin/install --list [--repo <owner/repo>] [--ref <git-ref>]

Creates:
  .agents/skill/<skill-name>/
    SKILL.md
    scripts/
    references/

Behavior:
  - Install from local source if available.
  - Else install from GitHub index (<repo>/<ref>).
  - Use --scaffold to force starter template creation.
EOF
}

skill_name=""
repo="$DEFAULT_REPO"
ref="$DEFAULT_REF"
scaffold_only=0
list_only=0

detect_local_index() {
  if [[ -f "$INDEX_FILE_JSON" ]]; then
    printf '%s|%s\n' "$INDEX_FILE_JSON" "json"
    return 0
  fi
  if [[ -f "$INDEX_FILE_TSV" ]]; then
    printf '%s|%s\n' "$INDEX_FILE_TSV" "tsv"
    return 0
  fi
  return 1
}

download_remote_index() {
  local remote_repo="$1"
  local remote_ref="$2"
  local outdir="$3"

  local json_url="https://raw.githubusercontent.com/${remote_repo}/${remote_ref}/${INDEX_FILE_JSON}"
  local tsv_url="https://raw.githubusercontent.com/${remote_repo}/${remote_ref}/${INDEX_FILE_TSV}"

  if curl -fsSL "$json_url" -o "$outdir/index.json" 2>/dev/null; then
    printf '%s|%s\n' "$outdir/index.json" "json"
    return 0
  fi
  if curl -fsSL "$tsv_url" -o "$outdir/index.tsv" 2>/dev/null; then
    printf '%s|%s\n' "$outdir/index.tsv" "tsv"
    return 0
  fi

  return 1
}

lookup_skill_source_json() {
  local query="$1"
  local index_path="$2"
  python3 - "$query" "$index_path" <<'PY'
import json
import sys

query = (sys.argv[1] or "").lower()
index_path = sys.argv[2]

try:
    with open(index_path, "r", encoding="utf-8") as f:
        data = json.load(f)
except Exception:
    sys.exit(0)

if isinstance(data, dict):
    items = data.get("skills", [])
elif isinstance(data, list):
    items = data
else:
    items = []

for item in items:
    if not isinstance(item, dict):
        continue
    if str(item.get("skill_name", "")).lower() == query:
        print(str(item.get("source_dir", "")))
        break
PY
}

lookup_skill_source_tsv() {
  local query="$1"
  local index_path="$2"
  awk -F'\t' -v q="$query" '
    BEGIN { q = tolower(q) }
    /^#/ { next }
    NF >= 2 {
      if (tolower($1) == q) {
        print $2
        exit
      }
    }
  ' "$index_path"
}

lookup_skill_source() {
  local query="$1"
  local index_path="$2"
  local index_format="$3"
  if [[ "$index_format" == "json" ]]; then
    lookup_skill_source_json "$query" "$index_path"
  else
    lookup_skill_source_tsv "$query" "$index_path"
  fi
}

print_skill_list_json() {
  local index_path="$1"
  python3 - "$index_path" <<'PY'
import json
import sys

index_path = sys.argv[1]

try:
    with open(index_path, "r", encoding="utf-8") as f:
        data = json.load(f)
except Exception:
    sys.exit(0)

if isinstance(data, dict):
    items = data.get("skills", [])
elif isinstance(data, list):
    items = data
else:
    items = []

for item in items:
    if not isinstance(item, dict):
        continue
    name = str(item.get("skill_name", "")).strip()
    if not name:
        continue
    desc = str(item.get("description", "")).strip()
    if desc:
        print(f"- {name}: {desc}")
    else:
        print(f"- {name}")
PY
}

print_skill_list_tsv() {
  local index_path="$1"
  awk -F'\t' '
    /^#/ { next }
    NF >= 2 {
      desc = (NF >= 3 ? $3 : "")
      if (desc != "") {
        printf "- %s: %s\n", $1, desc
      } else {
        printf "- %s\n", $1
      }
    }
  ' "$index_path"
}

print_skill_list() {
  local index_path="$1"
  local index_format="$2"
  if [[ "$index_format" == "json" ]]; then
    print_skill_list_json "$index_path"
  else
    print_skill_list_tsv "$index_path"
  fi
}

while [[ $# -gt 0 ]]; do
  case "$1" in
    --repo)
      repo="${2:-}"
      shift 2
      ;;
    --ref)
      ref="${2:-}"
      shift 2
      ;;
    --scaffold)
      scaffold_only=1
      shift
      ;;
    --list)
      list_only=1
      shift
      ;;
    -h|--help)
      usage
      exit 0
      ;;
    --*)
      echo "Error: unknown option: $1" >&2
      usage >&2
      exit 1
      ;;
    *)
      if [[ -n "$skill_name" ]]; then
        echo "Error: only one <skill-name> is supported." >&2
        usage >&2
        exit 1
      fi
      skill_name="$1"
      shift
      ;;
  esac
done

if [[ "$list_only" -eq 1 ]]; then
  if index_info="$(detect_local_index)"; then
    IFS='|' read -r index_path index_format <<<"$index_info"
    echo "Skills from local index (${index_path}):"
    print_skill_list "$index_path" "$index_format"
    exit 0
  fi

  tmpdir="$(mktemp -d)"
  trap 'rm -rf "$tmpdir"' EXIT
  if ! index_info="$(download_remote_index "$repo" "$ref" "$tmpdir")"; then
    echo "Error: could not download skill index: ${repo}@${ref} (${INDEX_FILE_JSON} or ${INDEX_FILE_TSV})" >&2
    exit 1
  fi
  IFS='|' read -r index_path index_format <<<"$index_info"
  echo "Skills from ${repo}@${ref}:"
  print_skill_list "$index_path" "$index_format"
  exit 0
fi

if [[ -z "$skill_name" ]]; then
  usage >&2
  exit 1
fi

if [[ "$skill_name" =~ [[:space:]/] ]]; then
  echo "Error: skill name must not contain spaces or '/': $skill_name" >&2
  exit 1
fi

if [[ ! "$skill_name" =~ ^[a-zA-Z0-9][a-zA-Z0-9._-]*$ ]]; then
  echo "Error: invalid skill name '$skill_name'." >&2
  echo "Allowed characters: letters, numbers, dot, underscore, hyphen." >&2
  exit 1
fi

copy_skill_dir() {
  local source_dir="$1"
  local dest="$2"

  mkdir -p "$dest/scripts" "$dest/references"
  cp "$source_dir/SKILL.md" "$dest/SKILL.md"

  if [[ -d "$source_dir/scripts" ]]; then
    cp -a "$source_dir/scripts/." "$dest/scripts/"
  fi
  if [[ -d "$source_dir/references" ]]; then
    cp -a "$source_dir/references/." "$dest/references/"
  fi

  if [[ -z "$(ls -A "$dest/scripts" 2>/dev/null)" ]]; then
    touch "$dest/scripts/.gitkeep"
  fi
  if [[ -z "$(ls -A "$dest/references" 2>/dev/null)" ]]; then
    touch "$dest/references/.gitkeep"
  fi
}

create_scaffold() {
  local skill="$1"
  local dest="$2"
  mkdir -p "$dest/scripts" "$dest/references"
  cat >"$dest/SKILL.md" <<EOF
---
name: $skill
description: TODO - add a short description
---

# $skill

## Purpose
TODO

## When to use
- TODO

## Inputs
- TODO

## Steps
1. TODO

## Output
- TODO
EOF
  touch "$dest/scripts/.gitkeep" "$dest/references/.gitkeep"
  echo "Created starter skill scaffold at: $dest"
}

dest=".agents/skill/$skill_name"

if [[ -e "$dest" ]]; then
  echo "Error: destination already exists: $dest" >&2
  exit 1
fi

source_dir=""
if [[ -f "$skill_name/SKILL.md" ]]; then
  source_dir="$skill_name"
elif index_info="$(detect_local_index)"; then
  IFS='|' read -r index_path index_format <<<"$index_info"
  mapped="$(lookup_skill_source "$skill_name" "$index_path" "$index_format")"
  if [[ -n "$mapped" && -f "$mapped/SKILL.md" ]]; then
    source_dir="$mapped"
  fi
fi

if [[ -n "$source_dir" ]]; then
  copy_skill_dir "$source_dir" "$dest"
  echo "Installed skill from local source: $source_dir -> $dest"
  exit 0
fi

# Remote install path (GitHub index + tarball).
if [[ "$scaffold_only" -ne 1 ]]; then
  tmpdir="$(mktemp -d)"
  trap 'rm -rf "$tmpdir"' EXIT

  if download_info="$(download_remote_index "$repo" "$ref" "$tmpdir")"; then
    IFS='|' read -r remote_index_path remote_index_format <<<"$download_info"
    remote_mapped="$(lookup_skill_source "$skill_name" "$remote_index_path" "$remote_index_format")"
    if [[ -n "$remote_mapped" ]]; then
      archive_url="https://codeload.github.com/${repo}/tar.gz/${ref}"
      curl -fsSL "$archive_url" -o "$tmpdir/repo.tar.gz"
      tar -xzf "$tmpdir/repo.tar.gz" -C "$tmpdir"

      extracted_root="$(find "$tmpdir" -mindepth 1 -maxdepth 1 -type d ! -name 'tmp.*' | head -n 1)"
      if [[ -z "$extracted_root" ]]; then
        echo "Error: failed to extract repository archive from $archive_url" >&2
        exit 1
      fi

      remote_source_dir="$extracted_root/$remote_mapped"
      if [[ ! -f "$remote_source_dir/SKILL.md" ]]; then
        echo "Error: remote skill path is invalid: $remote_mapped" >&2
        exit 1
      fi

      copy_skill_dir "$remote_source_dir" "$dest"
      echo "Installed skill from GitHub: ${repo}@${ref}:${remote_mapped} -> $dest"
      exit 0
    fi
  fi
fi

if [[ "$scaffold_only" -eq 1 ]]; then
  create_scaffold "$skill_name" "$dest"
  exit 0
fi

echo "Error: skill '$skill_name' was not found in local/remote index." >&2
echo "Use '--list' to see installable skills, or '--scaffold' to create a new template." >&2
exit 1
